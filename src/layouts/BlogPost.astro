---
import Layout from './Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ShareButtons from '../components/ShareButtons.astro';
import TagList from '../components/TagList.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  readingTime?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, readingTime = '5 min read', tags = [] } = Astro.props;

const fallbackSite = 'https://yannisspyrou.com';
let canonicalURL: URL;
try {
  canonicalURL = new URL(Astro.url.pathname, Astro.site || fallbackSite);
} catch {
  canonicalURL = new URL(fallbackSite);
}
---

<Layout title={title} description={description}>
  <article class="section-shell pt-12 pb-20">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-xs text-muted-foreground mb-3">
        <FormattedDate date={pubDate} />
        <span aria-hidden="true">·</span>
        <span>{readingTime}</span>
      </div>

      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-4">{title}</h1>
      <TagList tags={tags} />
    </header>

    {heroImage && (
      <div class="mb-10 overflow-hidden rounded-lg border border-border">
        <img src={heroImage} alt={title} class="w-full h-full object-cover" loading="eager" />
      </div>
    )}

    <div class="prose">
      <slot />
    </div>

    <div class="mt-12 pt-6 border-t border-border">
      <ShareButtons title={title} url={canonicalURL.toString()} />
    </div>

    {updatedDate && (
      <p class="mt-8 text-sm text-muted-foreground">
        Last updated on <FormattedDate date={updatedDate} />
      </p>
    )}
  </article>

  <slot name="after-article" />
</Layout>
