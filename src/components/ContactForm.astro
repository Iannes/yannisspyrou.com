---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<form
  name="contact"
  method="POST"
  action="/contact/success"
  data-netlify="true"
  data-netlify-honeypot="bot-field"
  class={`w-full rounded-2xl border border-zinc-200 dark:border-zinc-800 bg-white/70 dark:bg-zinc-900/60 backdrop-blur-sm p-5 sm:p-8 text-left ${className}`}
>
  <input type="hidden" name="form-name" value="contact" />
  <p class="hidden">
    <label>
      Don&apos;t fill this out:
      <input name="bot-field" autocomplete="off" tabindex="-1" />
    </label>
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
    <div>
      <label for="name" class="block text-sm font-medium text-zinc-800 dark:text-zinc-200 mb-2">
        Name
      </label>
      <input
        id="name"
        name="name"
        type="text"
        required
        minlength="2"
        maxlength="80"
        autocomplete="name"
        class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2.5 text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-500"
        placeholder="Your name"
      />
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-zinc-800 dark:text-zinc-200 mb-2">
        Email
      </label>
      <input
        id="email"
        name="email"
        type="email"
        required
        maxlength="120"
        inputmode="email"
        autocomplete="email"
        class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2.5 text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-500"
        placeholder="you@example.com"
      />
    </div>
  </div>

  <div class="mt-4 sm:mt-5">
    <label for="subject" class="block text-sm font-medium text-zinc-800 dark:text-zinc-200 mb-2">
      Subject
    </label>
    <input
      id="subject"
      name="subject"
      type="text"
      required
      minlength="4"
      maxlength="120"
      autocomplete="off"
      class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2.5 text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-500"
      placeholder="Project inquiry"
    />
  </div>

  <div class="mt-4 sm:mt-5">
    <label for="message" class="block text-sm font-medium text-zinc-800 dark:text-zinc-200 mb-2">
      Message
    </label>
    <textarea
      id="message"
      name="message"
      required
      minlength="20"
      maxlength="3000"
      rows="6"
      class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2.5 text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-500"
      placeholder="Tell me a bit about what you want to build."
    ></textarea>
  </div>

  <div class="mt-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <p class="text-xs text-zinc-500 dark:text-zinc-400">
      I usually reply within 1-2 business days.
    </p>
    <button
      type="submit"
      class="inline-flex items-center justify-center rounded-lg bg-zinc-900 dark:bg-zinc-100 px-5 py-2.5 text-sm font-medium text-zinc-100 dark:text-zinc-900 hover:bg-zinc-700 dark:hover:bg-zinc-300 transition-colors"
    >
      Send message
    </button>
  </div>
</form>
