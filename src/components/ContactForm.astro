---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<form
  name="contact"
  method="POST"
  action="/contact/success"
  data-netlify="true"
  data-netlify-honeypot="bot-field"
  class={`space-y-4 max-w-xl ${className}`}
>
  <input type="hidden" name="form-name" value="contact" />
  <p class="hidden">
    <label>
      Don&apos;t fill this out:
      <input name="bot-field" autocomplete="off" tabindex="-1" />
    </label>
  </p>

  <div>
    <label for="name" class="block text-sm font-medium text-foreground mb-1.5">Name</label>
    <input
      id="name"
      name="name"
      type="text"
      required
      minlength="2"
      maxlength="80"
      autocomplete="name"
      class="w-full px-3 py-2 text-sm bg-background border border-border rounded-md focus:outline-none focus:ring-1 focus:ring-[hsl(var(--ring))] text-foreground placeholder:text-muted-foreground"
      placeholder="Your name"
    />
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-foreground mb-1.5">Email</label>
    <input
      id="email"
      name="email"
      type="email"
      required
      maxlength="120"
      inputmode="email"
      autocomplete="email"
      class="w-full px-3 py-2 text-sm bg-background border border-border rounded-md focus:outline-none focus:ring-1 focus:ring-[hsl(var(--ring))] text-foreground placeholder:text-muted-foreground"
      placeholder="you@example.com"
    />
  </div>

  <div>
    <label for="subject" class="block text-sm font-medium text-foreground mb-1.5">Subject</label>
    <input
      id="subject"
      name="subject"
      type="text"
      required
      minlength="4"
      maxlength="120"
      autocomplete="off"
      class="w-full px-3 py-2 text-sm bg-background border border-border rounded-md focus:outline-none focus:ring-1 focus:ring-[hsl(var(--ring))] text-foreground placeholder:text-muted-foreground"
      placeholder="Project inquiry"
    />
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-foreground mb-1.5">Message</label>
    <textarea
      id="message"
      name="message"
      required
      minlength="20"
      maxlength="3000"
      rows="5"
      class="w-full px-3 py-2 text-sm bg-background border border-border rounded-md focus:outline-none focus:ring-1 focus:ring-[hsl(var(--ring))] text-foreground placeholder:text-muted-foreground resize-none"
      placeholder="Tell me a bit about what you want to build."
    ></textarea>
  </div>

  <div class="flex items-center justify-between gap-3 flex-wrap">
    <p class="text-xs text-muted-foreground">I usually reply within 1-2 business days.</p>
    <button
      type="submit"
      class="px-4 py-2 text-sm font-medium bg-primary text-primary-foreground rounded-md hover:opacity-90"
    >
      Send message
    </button>
  </div>
</form>
