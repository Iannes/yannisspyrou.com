---

<button
  type="button"
  data-theme-toggle
  class="text-muted-foreground hover:text-foreground transition-colors p-1"
  aria-label="Toggle theme"
>
  <svg data-theme-icon="moon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
  <svg data-theme-icon="sun" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4 hidden">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" />
    <circle cx="12" cy="12" r="5" />
  </svg>
</button>

<script>
  const darkQuery = window.matchMedia('(prefers-color-scheme: dark)');

  function applyTheme(theme) {
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }

  function getResolvedTheme() {
    const stored = localStorage.getItem('theme');
    if (stored === 'dark' || stored === 'light') return stored;
    return darkQuery.matches ? 'dark' : 'light';
  }

  function syncIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    document.querySelectorAll('[data-theme-toggle]').forEach((toggle) => {
      const moon = toggle.querySelector('[data-theme-icon="moon"]');
      const sun = toggle.querySelector('[data-theme-icon="sun"]');
      moon?.classList.toggle('hidden', isDark);
      sun?.classList.toggle('hidden', !isDark);
    });
  }

  function setupThemeToggle() {
    applyTheme(getResolvedTheme());
    syncIcons();

    document.querySelectorAll('[data-theme-toggle]').forEach((toggle) => {
      if (toggle.hasAttribute('data-theme-ready')) return;
      toggle.setAttribute('data-theme-ready', 'true');
      toggle.addEventListener('click', () => {
        const next = document.documentElement.classList.contains('dark') ? 'light' : 'dark';
        localStorage.setItem('theme', next);
        applyTheme(next);
        syncIcons();
      });
    });
  }

  darkQuery.addEventListener('change', () => {
    if (!localStorage.getItem('theme')) {
      applyTheme(getResolvedTheme());
      syncIcons();
    }
  });

  document.addEventListener('DOMContentLoaded', setupThemeToggle);
  document.addEventListener('astro:page-load', setupThemeToggle);
</script>
