---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { text: 'Blog', href: '/blog' },
  { text: 'Tags', href: '/tags' },
  { text: 'About', href: '/about' },
];

const pathname = new URL(Astro.request.url).pathname;
---

<header class="sticky top-0 z-50 bg-background/80 backdrop-blur-md border-b border-[hsl(var(--nav-border))]">
  <nav class="section-shell h-14 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-foreground hover:text-foreground/80">Yannis</a>

    <div class="hidden sm:flex items-center gap-6">
      {navItems.map((item) => {
        const isActive = pathname.startsWith(item.href);
        return (
          <a
            href={item.href}
            class={`text-sm transition-colors ${isActive ? 'text-foreground font-medium' : 'text-muted-foreground hover:text-foreground'}`}
          >
            {item.text}
          </a>
        );
      })}
      <ThemeToggle />
    </div>

    <div class="flex sm:hidden items-center gap-3">
      <ThemeToggle />
      <button
        id="mobile-menu-button"
        type="button"
        class="text-muted-foreground hover:text-foreground transition-colors p-1"
        aria-label="Toggle menu"
      >
        <svg data-menu-icon="open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-[18px] w-[18px]">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg data-menu-icon="close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-[18px] w-[18px] hidden">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="sm:hidden hidden border-t border-[hsl(var(--nav-border))] bg-background">
    <div class="section-shell py-4 flex flex-col gap-3">
      {navItems.map((item) => {
        const isActive = pathname.startsWith(item.href);
        return (
          <a
            href={item.href}
            class={`text-sm transition-colors ${isActive ? 'text-foreground font-medium' : 'text-muted-foreground hover:text-foreground'}`}
          >
            {item.text}
          </a>
        );
      })}
    </div>
  </div>
</header>

<script>
  function setupMobileMenu() {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    if (!button || !menu || button.hasAttribute('data-menu-ready')) return;

    button.setAttribute('data-menu-ready', 'true');

    button.addEventListener('click', () => {
      const expanded = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', expanded);
      const openIcon = button.querySelector('[data-menu-icon="open"]');
      const closeIcon = button.querySelector('[data-menu-icon="close"]');
      openIcon?.classList.toggle('hidden', !expanded);
      closeIcon?.classList.toggle('hidden', expanded);
    });
  }

  document.addEventListener('DOMContentLoaded', setupMobileMenu);
  document.addEventListener('astro:page-load', setupMobileMenu);
</script>
