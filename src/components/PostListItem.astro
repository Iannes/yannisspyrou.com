---
interface Props {
  title: string;
  dateLabel: string;
  dateIso: string;
  excerpt: string;
  href: string;
  tags?: string[];
}

const { title, dateLabel, dateIso, excerpt, href, tags = [] } = Astro.props;
---

<article class="group py-6 first:pt-0 border-b border-border last:border-0">
  <a href={href} class="block">
    <div class="flex flex-col gap-2">
      <div class="flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
        <time datetime={dateIso}>{dateLabel}</time>
        {tags.length > 0 && (
          <>
            <span aria-hidden="true">·</span>
            <div class="flex flex-wrap gap-1.5">
              {tags.slice(0, 3).map((tag) => (
                <span class="text-xs text-muted-foreground">{tag}</span>
              ))}
            </div>
          </>
        )}
      </div>
      <h3 class="text-2xl font-semibold tracking-tight text-foreground group-hover:text-accent">{title}</h3>
      <p class="text-sm text-muted-foreground leading-relaxed">{excerpt}</p>
    </div>
  </a>
</article>
