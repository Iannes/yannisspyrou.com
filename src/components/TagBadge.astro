---
interface Props {
  tag: string;
  count?: number;
  href?: string;
}

const { tag, count, href = `/tags/${encodeURIComponent(tag)}` } = Astro.props;
---

<a
  href={href}
  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs text-muted-foreground bg-secondary rounded-md hover:text-foreground hover:bg-muted border border-border"
>
  <span>{tag}</span>
  {count !== undefined && <span class="text-muted-foreground/60">{count}</span>}
</a>
