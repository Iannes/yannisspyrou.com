---
const currentYear = new Date().getFullYear();

const navLinks = [
  { text: 'About', href: '/about' },
  { text: 'Blog', href: '/blog' },
  { text: 'Tags', href: '/tags' },
  { text: 'Contact', href: '/about#contact' },
];

const socialLinks = [
  { name: 'X', href: 'https://x.com/SpyrouYannis' },
  { name: 'GitHub', href: 'https://github.com/iannes' },
  { name: 'LinkedIn', href: 'https://www.linkedin.com/in/yannis-spyrou-8624ab25' },
];
---

<footer class="mt-20 border-t border-zinc-200 dark:border-zinc-800">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <a href="/" class="inline-flex items-center gap-2 font-semibold text-zinc-900 dark:text-zinc-100">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-zinc-900 text-zinc-100 dark:bg-zinc-100 dark:text-zinc-900">YS</span>
          <span>Yannis</span>
        </a>
        <p class="mt-3 text-sm text-zinc-600 dark:text-zinc-400">
          Frontend engineering notes on React, TypeScript, and product UI.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-800 dark:text-zinc-200">Navigation</h3>
        <ul class="mt-3 space-y-2">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-800 dark:text-zinc-200">Social</h3>
        <ul class="mt-3 space-y-2">
          {socialLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-zinc-200 dark:border-zinc-800 text-xs text-zinc-500 dark:text-zinc-400">
      © {currentYear} Yannis Spyrou. Built with Astro.
    </div>
  </div>
</footer>
