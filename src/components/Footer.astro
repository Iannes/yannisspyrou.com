---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border mt-20">
  <div class="section-shell py-10 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-xs text-muted-foreground">© {currentYear} Yannis Spyrou. All rights reserved.</p>
    <div class="flex items-center gap-4">
      <a
        href="https://github.com/iannes"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-muted-foreground hover:text-foreground"
        aria-label="GitHub"
      >GitHub</a>
      <a
        href="https://x.com/SpyrouYannis"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-muted-foreground hover:text-foreground"
        aria-label="X"
      >X</a>
      <a
        href="https://www.linkedin.com/in/yannis-spyrou-8624ab25"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-muted-foreground hover:text-foreground"
        aria-label="LinkedIn"
      >LinkedIn</a>
    </div>
  </div>
</footer>
