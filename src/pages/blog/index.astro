---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostListItem from '../../components/PostListItem.astro';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog">
  <section class="section-shell pt-16 pb-20">
    <h1 class="text-4xl font-bold tracking-tight text-foreground mb-2">Blog</h1>
    <p class="text-base text-muted-foreground mb-10">
      Thoughts on frontend engineering, architecture, and developer tools.
    </p>

    <div class="divide-y divide-border">
      {sortedPosts.map((post) => (
        <PostListItem
          title={post.data.title}
          dateLabel={post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          dateIso={post.data.pubDate.toISOString()}
          excerpt={post.data.description}
          href={`/blog/${post.slug}`}
          tags={post.data.tags ?? []}
        />
      ))}
    </div>
  </section>
</BaseLayout>
