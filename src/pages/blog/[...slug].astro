---
import { getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');

  const sortedEntries = [...blogEntries]
    .filter((entry) => !entry.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return sortedEntries.map((entry, index) => {
    const wordCount = entry.body.trim().split(/\s+/).length;
    const readingTimeValue = `${Math.max(1, Math.ceil(wordCount / 220))} min read`;

    return {
      params: { slug: entry.slug },
      props: {
        entry,
        readingTimeValue,
        nextPost: index > 0 ? sortedEntries[index - 1] : null,
        prevPost: index < sortedEntries.length - 1 ? sortedEntries[index + 1] : null,
      },
    };
  });
}

const { entry, nextPost, prevPost, readingTimeValue } = Astro.props;
const { Content } = await entry.render();

const finalReadingTime = entry.data.readingTime || readingTimeValue;
---

<BlogPost {...entry.data} readingTime={finalReadingTime}>
  <Content />

  <div slot="after-article" class="section-shell pb-20">
    {(prevPost || nextPost) && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-2">
        {prevPost ? (
          <a
            href={`/blog/${prevPost.slug}`}
            class="block rounded-lg border border-border p-4 hover:bg-secondary"
          >
            <p class="text-xs text-muted-foreground mb-1">Previous</p>
            <p class="text-sm font-medium text-foreground">{prevPost.data.title}</p>
          </a>
        ) : <div></div>}

        {nextPost && (
          <a
            href={`/blog/${nextPost.slug}`}
            class="block rounded-lg border border-border p-4 hover:bg-secondary md:text-right"
          >
            <p class="text-xs text-muted-foreground mb-1">Next</p>
            <p class="text-sm font-medium text-foreground">{nextPost.data.title}</p>
          </a>
        )}
      </div>
    )}
  </div>
</BlogPost>
