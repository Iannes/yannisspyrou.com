---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostListItem from '../components/PostListItem.astro';
import TagBadge from '../components/TagBadge.astro';

const allPosts = await getCollection('blog');

const visiblePosts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const recentPosts = visiblePosts.slice(0, 3);

const tagCounts = new Map<string, number>();
for (const post of visiblePosts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const featuredTags = [...tagCounts.entries()]
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag))
  .slice(0, 8);
---

<BaseLayout title="Yannis Spyrou | Dev Blog">
  <section class="section-shell pt-16 pb-12">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-4">Hi, I&apos;m Yannis.</h1>
    <p class="text-lg text-muted-foreground max-w-xl">
      I build fast, accessible web applications and share practical notes on frontend engineering, system design, and building reliable UI systems.
    </p>
  </section>

  <section class="section-shell pb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-3xl font-semibold tracking-tight text-foreground">Recent posts</h2>
      <a href="/blog" class="text-sm text-muted-foreground hover:text-foreground">All posts</a>
    </div>
    <div class="divide-y divide-border">
      {recentPosts.map((post) => (
        <PostListItem
          title={post.data.title}
          dateLabel={post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          dateIso={post.data.pubDate.toISOString()}
          excerpt={post.data.description}
          href={`/blog/${post.slug}`}
          tags={post.data.tags ?? []}
        />
      ))}
    </div>
  </section>

  <section class="section-shell pb-20">
    <h2 class="text-3xl font-semibold tracking-tight text-foreground mb-4">Topics</h2>
    <div class="flex flex-wrap gap-2">
      {featuredTags.map(({ tag, count }) => (
        <TagBadge tag={tag} count={count} />
      ))}
    </div>
  </section>
</BaseLayout>
