---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="About" description="I'm Yannis, a frontend engineer working with React and TypeScript.">
  <section class="section-shell pt-16 pb-20">
    <h1 class="text-4xl font-bold tracking-tight text-foreground mb-6">About</h1>

    <div class="prose mb-12">
      <p>
        I build performant, accessible user interfaces and frontend systems that stay maintainable as products scale.
        I focus on turning complex requirements into simple experiences.
      </p>
      <p>
        My day-to-day work is mostly React and TypeScript, with an emphasis on reliability, performance, and clear architecture.
      </p>
    </div>

    <section>
      <h2 class="text-3xl font-semibold tracking-tight text-foreground mb-4">Get in touch</h2>
      <p class="text-base text-muted-foreground mb-6">
        Have a question or want to collaborate? Drop me a message.
      </p>
      <ContactForm />
    </section>
  </section>
</BaseLayout>
