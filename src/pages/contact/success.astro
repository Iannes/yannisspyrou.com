---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Message Sent" description="Thanks for your message. I will get back to you soon.">
  <section class="max-w-2xl mx-auto py-10 sm:py-16 px-4 sm:px-6 text-center">
    <div class="rounded-2xl border border-zinc-200 dark:border-zinc-800 bg-white/70 dark:bg-zinc-900/60 backdrop-blur-sm p-8 sm:p-10">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
        Thanks, your message was sent.
      </h1>
      <p class="mt-4 text-zinc-600 dark:text-zinc-400">
        I received your submission and will reply as soon as possible.
      </p>
      <div class="mt-8">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-lg bg-zinc-900 dark:bg-zinc-100 px-5 py-2.5 text-sm font-medium text-zinc-100 dark:text-zinc-900 hover:bg-zinc-700 dark:hover:bg-zinc-300 transition-colors"
        >
          Back to home
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
