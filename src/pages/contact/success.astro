---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Message Sent" description="Thanks for your message. I will get back to you soon.">
  <section class="section-shell pt-16 pb-20">
    <h1 class="text-4xl font-bold tracking-tight text-foreground mb-4">Thanks, your message was sent.</h1>
    <p class="text-base text-muted-foreground mb-8">
      I received your submission and will reply as soon as possible.
    </p>
    <a
      href="/"
      class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium bg-primary text-primary-foreground rounded-md hover:opacity-90"
    >
      Back to home
    </a>
  </section>
</BaseLayout>
