---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found">
  <section class="section-shell pt-20 pb-24 text-center">
    <p class="text-sm text-muted-foreground mb-2">404</p>
    <h1 class="text-4xl font-bold tracking-tight text-foreground mb-4">Page not found</h1>
    <p class="text-base text-muted-foreground mb-8">The page you requested does not exist.</p>

    <div class="flex items-center justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium bg-primary text-primary-foreground rounded-md hover:opacity-90"
      >
        Return home
      </a>
      <button
        type="button"
        id="back-button"
        class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium border border-border rounded-md text-foreground hover:bg-secondary"
      >
        Go back
      </button>
    </div>
  </section>
</Layout>

<script>
  const backButton = document.getElementById('back-button');
  backButton?.addEventListener('click', () => {
    window.history.back();
  });
</script>
